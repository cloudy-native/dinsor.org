---
---

<nav class="fixed top-0 z-40 w-full border-b border-gray-200 bg-background/80 backdrop-blur-lg dark:border-gray-800">
  <div class="container mx-auto flex max-w-7xl items-center justify-between px-6 h-16">
    <!-- Brand -->
    <a href="/" class="flex items-center gap-2 text-xl font-semibold tracking-tight">
      <span>✏️</span>
      <span>Dinsor</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8 text-sm">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <a href="/about" class="hover:text-primary transition-colors">About</a>
    </div>

    <!-- Mobile -->
    <div class="md:hidden flex items-center gap-2">
      <button id="mobile-menu-btn" class="p-2" aria-label="Toggle menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-background dark:border-gray-800">
    <div class="container mx-auto max-w-7xl px-6 py-4 flex flex-col gap-4 text-sm">
      <a href="/" class="py-1">Home</a>
      <a href="/about" class="py-1">About</a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>