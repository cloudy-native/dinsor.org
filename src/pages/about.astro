---
import Layout from '../layouts/Layout.astro';

const title = "About | Dinsor";
const description = "About Stephen Harrison (Dinsor) — making things at the intersection of art and technology.";
---

<Layout title={title} description={description}>
	<section class="flex flex-col items-center justify-center gap-8 py-8 md:py-10">
		<div class="max-w-3xl w-full">
			<h1 class="text-5xl font-bold mb-8">✏️ About Me</h1>

			<div class="space-y-6 text-lg text-default-700">
				<p>I make things at the intersection of art and tech.</p>
				<p>
					Take a look around and feel free to explore my portfolios and get
					in touch if you'd like to collaborate.
				</p>
			</div>
		</div>
	</section>
</Layout>